# Copy this file to .env for local development.
# On Railway, add these values in the service Variables tab instead of committing a real .env file.

# Preferred single database variable.
DATABASE_URL=mysql://username:password@host:3306/database_name

# Optional fallback database variables if you do not use DATABASE_URL.
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=attendance system_mysql
DB_USERNAME=root
DB_PASSWORD=

# Public app URL used when generating QR links.
# Local example:
APP_BASE_URL=http://localhost/attendance-system
# Railway example after deployment:
# APP_BASE_URL=https://your-app-name.up.railway.app

APP_TIMEZONE=Africa/Lagos
LECTURER_INVITE_CODE=SMART-LECTURER-2026
NODE_BINARY=node
APP_LOG_DIR=
UPLOAD_DIR=

# Migrations run automatically during app startup unless disabled.
RUN_MIGRATIONS=true

# Optional first admin seed. Used only if no admin exists yet.
ADMIN_NAME=System Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-password
